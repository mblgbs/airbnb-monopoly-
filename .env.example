# PostgreSQL connection string (Prisma)
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/airbnb_monopoly?schema=public"

# Secret for JWT session cookies (min 32 random bytes in production)
JWT_SECRET="change-me-to-a-long-random-string-at-least-32-chars"

# Public app URL (optional, defaults to http://localhost:3000)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Central payments gateway (services-Monopoly-)
SERVICES_MONOPOLY_BASE_URL="http://127.0.0.1:8004"
